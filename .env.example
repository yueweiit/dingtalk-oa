# PostgreSQL 数据库配置
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password
PGDATABASE=dingtalk_oa

# 钉钉应用配置
DINGTALK_APP_KEY=your_app_key
DINGTALK_APP_SECRET=your_app_secret

# 钉钉企业 ID（可选，首次收到事件时自动获取）
DINGTALK_CORP_ID=your_corp_id

# Kafka 配置（可选，暂未安装时可留空）
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=dingtalk-oa
KAFKA_GROUP_ID=dingtalk-oa-group

# Webhook 配置（备用）
WEBHOOK_TOKEN=your_webhook_token
WEBHOOK_AES_KEY=your_aes_key

# Backfill 配置
BACKFILL_LOOKBACK_DAYS=1
BACKFILL_WINDOW_DAYS=30

# 日志级别
LOG_LEVEL=info

# 服务端口
PORT=3000
